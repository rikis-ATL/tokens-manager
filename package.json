{
  "name": "token-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "."
  ],
  "scripts": {
    "dev": "npx tsx server.ts",
    "dev:next": "next dev",
    "dev:clean": "rm -rf .next && npx tsx server.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "seed": "DOTENV_CONFIG_PATH=.env.local npx ts-node --transpile-only -r dotenv/config --project tsconfig.scripts.json scripts/seed.ts",
    "seed:demo": "DOTENV_CONFIG_PATH=.env.local npx ts-node --transpile-only -r dotenv/config --project tsconfig.scripts.json scripts/seed-demo.ts",
    "migrate:themes": "DOTENV_CONFIG_PATH=.env.local npx ts-node --transpile-only -r dotenv/config --project tsconfig.scripts.json scripts/migrate-theme-tokens.ts",
    "dev:stencil": "yarn workspace token-manager-stencil dev",
    "build:stencil": "yarn workspace token-manager-stencil build",
    "start:stencil": "yarn workspace token-manager-stencil start",
    "dev:vite": "yarn workspace token-manager-vite dev",
    "build:vite": "yarn workspace token-manager-vite build",
    "preview:vite": "yarn workspace token-manager-vite preview",
    "mcp:dev": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config --tsconfig tsconfig.scripts.json src/mcp/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.99.1",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.0.0",
    "mongoose": "^9.2.2",
    "next": "13.5.9",
    "next-auth": "^4.24.13",
    "react": "18.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "18.2.0",
    "react-resizable-panels": "^4.7.2",
    "resend": "^6.9.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "style-dictionary": "^5.3.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "18.17.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "autoprefixer": "10.4.16",
    "dotenv": "^17.3.1",
    "eslint": "8.57.0",
    "eslint-config-next": "13.5.9",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "8.4.31",
    "tailwindcss": "3.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.2.2"
  }
}
