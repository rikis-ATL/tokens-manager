{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.typecheck.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "server.ts",
    "jest.config.ts",
    "jest.setup.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".claude",
    "packages",
    "token-manager-angular",
    "token-manager-stencil",
    "token-manager-vite"
  ]
}
