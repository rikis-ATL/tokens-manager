{
  "color": {
    "brand": {
      "$type": "color",
      "primary": { "$value": "#F97316", "$description": "Lovable orange — primary brand, CTAs" },
      "primaryLight": { "$value": "#FB923C", "$description": "Hover, lighter accent" },
      "primaryDark": { "$value": "#EA580C", "$description": "Pressed, deep accent" },
      "violet": { "$value": "#8B5CF6", "$description": "Secondary brand — AI / generation accent" },
      "violetLight": { "$value": "#A78BFA", "$description": "Gradient end, subtle highlights" }
    },
    "neutral": {
      "$type": "color",
      "0": { "$value": "#FFFFFF", "$description": "Page background, card surfaces" },
      "50": { "$value": "#FAFAFA", "$description": "App shell background" },
      "100": { "$value": "#F4F4F5", "$description": "Sidebar, secondary surfaces" },
      "200": { "$value": "#E4E4E7", "$description": "Borders, dividers" },
      "400": { "$value": "#A1A1AA", "$description": "Placeholder, disabled" },
      "600": { "$value": "#52525B", "$description": "Secondary text" },
      "800": { "$value": "#27272A", "$description": "Primary text dark" },
      "900": { "$value": "#18181B", "$description": "Near-black, headings" }
    },
    "surface": {
      "$type": "color",
      "editor": { "$value": "#0F0F11", "$description": "Code editor dark bg" },
      "editorBorder": { "$value": "#27272A", "$description": "Editor panel borders" },
      "preview": { "$value": "#FFFFFF", "$description": "Live preview iframe bg" },
      "chat": { "$value": "#F9F9FB", "$description": "Chat panel surface" },
      "promptBubble": { "$value": "#FFF7ED", "$description": "User prompt bubble — warm orange tint" }
    },
    "semantic": {
      "$type": "color",
      "success": { "$value": "#22C55E", "$description": "Build success, deployed" },
      "warning": { "$value": "#F59E0B", "$description": "Caution, partial" },
      "error": { "$value": "#EF4444", "$description": "Build error, destructive" },
      "info": { "$value": "#3B82F6", "$description": "Info states" }
    }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "sans": {
      "$value": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica Neue, Arial, sans-serif",
      "$description": "Primary UI typeface"
    },
    "mono": {
      "$value": "Fira Code, JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
      "$description": "Code editor, generated code display"
    }
  },
  "fontSize": {
    "$type": "fontSize",
    "hero": { "$value": "3.5rem", "$description": "56px — Marketing hero" },
    "h1": { "$value": "2.25rem", "$description": "36px — Page title" },
    "h2": { "$value": "1.875rem", "$description": "30px — Section heading" },
    "h3": { "$value": "1.5rem", "$description": "24px — Card heading" },
    "bodyLarge": { "$value": "1.125rem", "$description": "18px — Intro / feature copy" },
    "body": { "$value": "1rem", "$description": "16px — Standard UI" },
    "small": { "$value": "0.875rem", "$description": "14px — Labels, sidebar items" },
    "xs": { "$value": "0.75rem", "$description": "12px — Code captions, meta" }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": "400" },
    "medium": { "$value": "500", "$description": "UI elements" },
    "semibold": { "$value": "600", "$description": "Headings, feature titles" },
    "bold": { "$value": "700", "$description": "Hero, strong CTAs" }
  },
  "lineHeight": {
    "$type": "lineHeight",
    "tight": { "$value": "1.1", "$description": "Hero display" },
    "snug": { "$value": "1.35", "$description": "Headings" },
    "normal": { "$value": "1.5", "$description": "Body UI" },
    "relaxed": { "$value": "1.65", "$description": "Marketing copy" }
  },
  "letterSpacing": {
    "$type": "letterSpacing",
    "tight": { "$value": "-0.03em", "$description": "Hero display" },
    "snug": { "$value": "-0.01em", "$description": "Headings" },
    "normal": { "$value": "0em", "$description": "Body" }
  },
  "dimension": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px", "$description": "Base unit" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px" },
    "6": { "$value": "32px" },
    "7": { "$value": "48px" },
    "8": { "$value": "64px" },
    "9": { "$value": "80px" },
    "editorPanelWidth": { "$value": "320px", "$description": "Prompt / settings panel width" },
    "previewMinWidth": { "$value": "375px", "$description": "Minimum preview width" }
  },
  "borderRadius": {
    "$type": "borderRadius",
    "sm": { "$value": "4px", "$description": "Small chips, badges" },
    "md": { "$value": "8px", "$description": "Inputs, buttons" },
    "lg": { "$value": "12px", "$description": "Cards, panels" },
    "xl": { "$value": "16px", "$description": "Feature cards, modals" },
    "2xl": { "$value": "24px", "$description": "Hero cards, preview frames" },
    "pill": { "$value": "9999px", "$description": "Tags, version badges" }
  },
  "breakpoint": {
    "$type": "dimension",
    "mobile": { "$value": "375px" },
    "tablet": { "$value": "768px" },
    "desktop": { "$value": "1024px" },
    "wide": { "$value": "1440px" }
  },
  "shadow": {
    "$type": "string",
    "sm": { "$value": "0 1px 4px rgba(0,0,0,0.08)", "$description": "Cards, inputs" },
    "md": { "$value": "0 4px 16px rgba(0,0,0,0.12)", "$description": "Dropdowns, popovers" },
    "lg": { "$value": "0 8px 32px rgba(0,0,0,0.16)", "$description": "Modals" },
    "glow": { "$value": "0 0 32px rgba(249,115,22,0.25)", "$description": "Brand orange glow — generation in progress" }
  }
}
