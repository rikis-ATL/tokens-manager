    },
    "subtleElevation": {
      "$value": "rgba(0, 0, 0, 0.04) 0px 2px 2px",
      "$description": "Minimal card lift"
    },
    "ringBorderLight": {
      "$value": "rgb(235, 235, 235) 0px 0px 0px 1px",
      "$description": "Tabs, images"
    },
    "cardStack": {
      "$value": "rgba(0,0,0,0.08) 0px 0px 0px 1px, rgba(0,0,0,0.04) 0px 2px 2px, rgba(0,0,0,0.04) 0px 8px 8px -8px, #fafafa 0px 0px 0px 1px",
