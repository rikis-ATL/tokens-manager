    "bodyLarge": { "$value": "1.80", "$description": "Relaxed intros" },
    "body": { "$value": "1.56", "$description": "18px body" },
    "bodySmall": { "$value": "1.50", "$description": "16px UI" },
    "button": { "$value": "1.43", "$description": "14px buttons" },
