      "ring": { "$value": "rgba(147, 197, 253, 0.5)", "$description": "Tailwind ring utility" }
    },
    "surface": {
      "$type": "color",
      "overlayBackdrop": { "$value": "hsla(0, 0%, 98%, 1)", "$description": "Modal/dialog backdrop" },
