    "subtle": { "$value": "4px", "$description": "Small containers" },
    "standard": { "$value": "6px", "$description": "Buttons, links" },
    "comfortable": { "$value": "8px", "$description": "Cards, list items" },
    "image": { "$value": "12px", "$description": "Featured cards (often top-only in CSS)" },
