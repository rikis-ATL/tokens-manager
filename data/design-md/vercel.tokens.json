    "5": { "$value": "5px" },
    "6": { "$value": "6px" },
    "8": { "$value": "8px", "$description": "Base unit" },
    "10": { "$value": "10px" },
    "12": { "$value": "12px" },
    "14": { "$value": "14px" },
    "16": { "$value": "16px" },
    "32": { "$value": "32px", "$description": "Jump after 16px in primary scale" },
    "36": { "$value": "36px" },
    "40": { "$value": "40px" },
    "sectionPaddingLo": { "$value": "48px", "$description": "Mobile section spacing" },
    "sectionPaddingHi": { "$value": "80px", "$description": "Desktop section rhythm (doc: 80–120px+)" },
    "containerMax": { "$value": "1200px", "$description": "Approx max content width" },
    "buttonPaddingY": { "$value": "8px", "$description": "Primary dark button vertical" },
