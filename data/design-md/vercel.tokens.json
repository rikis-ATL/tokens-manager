{
  "color": {
    "neutral": {
      "$type": "color",
      "50": { "$value": "#fafafa", "$description": "Subtle surface tint, inner shadow highlight" },
      "100": { "$value": "#ebebeb", "$description": "Borders, card outlines, dividers" },
      "400": { "$value": "#808080", "$description": "Placeholder text, disabled states" },
      "500": { "$value": "#666666", "$description": "Tertiary text, muted links" },
      "600": { "$value": "#4d4d4d", "$description": "Secondary text, description copy" },
      "900": { "$value": "#171717", "$description": "Primary text, headings, nav (Vercel Black)" }
    },
    "canvas": {
      "$type": "color",
      "white": { "$value": "#ffffff", "$description": "Page background, card surfaces, button text on dark" },
      "black": { "$value": "#000000", "$description": "Console/code contexts (--geist-console-text-color-default)" }
    },
    "workflow": {
      "$type": "color",
      "develop": { "$value": "#0a72ef", "$description": "Develop workflow accent" },
      "preview": { "$value": "#de1d8d", "$description": "Preview deployment workflow" },
      "ship": { "$value": "#ff5b4f", "$description": "Ship to production workflow" }
    },
    "console": {
      "$type": "color",
      "blue": { "$value": "#0070f3", "$description": "Syntax highlighting blue" },
      "purple": { "$value": "#7928ca", "$description": "Syntax highlighting purple" },
      "pink": { "$value": "#eb367f", "$description": "Syntax highlighting pink" }
    },
    "interactive": {
      "$type": "color",
