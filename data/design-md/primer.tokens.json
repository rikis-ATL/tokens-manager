    "shadowLarge": { "$value": "0 8px 24px rgba(140,149,159,0.2)", "$description": "Modal, command palette" },
    "shadowExtraLarge": { "$value": "0 12px 48px rgba(140,149,159,0.3)", "$description": "Menus, large overlays" },
