    "$type": "string",
    "card": { "$value": "0 1px 1px rgba(9,30,66,0.25), 0 0 1px rgba(9,30,66,0.31)", "$description": "Jira card default" },
    "cardHover": { "$value": "0 4px 8px -2px rgba(9,30,66,0.25), 0 0 1px rgba(9,30,66,0.31)", "$description": "Card hover lift" },
    "overlay": { "$value": "0 8px 16px -4px rgba(9,30,66,0.25), 0 0 1px rgba(9,30,66,0.31)", "$description": "Dropdown, tooltip" },
    "modal": { "$value": "0 20px 32px -8px rgba(9,30,66,0.25), 0 0 1px rgba(9,30,66,0.31)", "$description": "Modal dialog" }
