{
  "color": {
    "brand": {
      "$type": "color",
      "purple": { "$value": "#7B61FF", "$description": "Primary brand violet — CTAs, active states" },
      "blue": { "$value": "#18A0FB", "$description": "Selection blue — object selection rings, links" },
      "green": { "$value": "#1BC47D", "$description": "Success, component indicators" },
      "yellow": { "$value": "#FFEB00", "$description": "Component highlight, auto-layout stripes" },
      "red": { "$value": "#F24822", "$description": "Vector/path tool, destructive actions" }
    },
    "neutral": {
      "$type": "color",
      "0": { "$value": "#FFFFFF", "$description": "Canvas surface, panel backgrounds" },
      "100": { "$value": "#F5F5F5", "$description": "Sidebar background" },
      "200": { "$value": "#E5E5E5", "$description": "Borders, dividers, input outlines" },
      "400": { "$value": "#B3B3B3", "$description": "Placeholder text, disabled icons" },
      "600": { "$value": "#616161", "$description": "Secondary text, labels" },
      "900": { "$value": "#1E1E1E", "$description": "Primary text, editor canvas dark bg" }
    },
    "editor": {
      "$type": "color",
      "canvasBg": { "$value": "#F5F5F5", "$description": "Design canvas background" },
      "selectionFill": { "$value": "rgba(24, 160, 251, 0.1)", "$description": "Marquee selection fill" },
      "gridLine": { "$value": "rgba(255, 0, 0, 0.1)", "$description": "Layout grid overlay" },
      "guide": { "$value": "#FF00FF", "$description": "Ruler guide lines" }
    }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "sans": {
      "$value": "Inter, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
      "$description": "Figma UI primary — Inter throughout the product"
    },
    "mono": {
      "$value": "Roboto Mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Courier New",
      "$description": "Code, token values, layer panel specifics"
    }
  },
  "fontSize": {
    "$type": "fontSize",
    "hero": { "$value": "2.5rem", "$description": "40px — Marketing hero" },
    "h1": { "$value": "2rem", "$description": "32px — Section headings" },
    "h2": { "$value": "1.5rem", "$description": "24px — Panel headings" },
    "h3": { "$value": "1.25rem", "$description": "20px — Card headings" },
    "body": { "$value": "1rem", "$description": "16px — Standard reading" },
    "small": { "$value": "0.875rem", "$description": "14px — UI labels, sidebars" },
    "xs": { "$value": "0.75rem", "$description": "12px — Captions, tooltips, layer names" },
    "micro": { "$value": "0.6875rem", "$description": "11px — Toolbar icons labels" }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": "400", "$description": "Body copy" },
    "medium": { "$value": "500", "$description": "UI interactive elements" },
    "semibold": { "$value": "600", "$description": "Headings, emphasis" },
    "bold": { "$value": "700", "$description": "Strong emphasis, CTAs" }
  },
  "lineHeight": {
    "$type": "lineHeight",
    "tight": { "$value": "1.2", "$description": "Display/hero text" },
    "snug": { "$value": "1.35", "$description": "Headings" },
    "normal": { "$value": "1.5", "$description": "Body text" },
    "relaxed": { "$value": "1.6", "$description": "Long-form reading" }
  },
  "letterSpacing": {
    "$type": "letterSpacing",
    "tight": { "$value": "-0.02em", "$description": "Large display text" },
    "normal": { "$value": "0em", "$description": "Body and UI" },
    "wide": { "$value": "0.04em", "$description": "Uppercase labels, badges" }
  },
  "dimension": {
    "$type": "dimension",
    "1": { "$value": "2px" },
    "2": { "$value": "4px" },
    "3": { "$value": "8px", "$description": "Base unit" },
    "4": { "$value": "12px" },
    "5": { "$value": "16px" },
    "6": { "$value": "24px" },
    "7": { "$value": "32px" },
    "8": { "$value": "40px" },
    "9": { "$value": "48px" },
    "10": { "$value": "64px" },
    "sidebarWidth": { "$value": "240px", "$description": "Left panel default width" },
    "inspectorWidth": { "$value": "240px", "$description": "Right panel default width" },
    "toolbarHeight": { "$value": "40px", "$description": "Top toolbar height" }
  },
  "borderRadius": {
    "$type": "borderRadius",
    "none": { "$value": "0px" },
    "xs": { "$value": "2px", "$description": "Input fields, small chips" },
    "sm": { "$value": "4px", "$description": "Buttons, dropdowns" },
    "md": { "$value": "6px", "$description": "Panels, popovers" },
    "lg": { "$value": "8px", "$description": "Cards, modals" },
    "pill": { "$value": "9999px", "$description": "Badge pills, tags" },
    "circle": { "$value": "50%", "$description": "Avatars" }
  },
  "breakpoint": {
    "$type": "dimension",
    "mobile": { "$value": "375px" },
    "tablet": { "$value": "768px" },
    "desktop": { "$value": "1024px" },
    "wide": { "$value": "1280px" }
  },
  "shadow": {
    "$type": "string",
    "xs": { "$value": "0 1px 2px rgba(0,0,0,0.08)", "$description": "Minimal lift" },
    "sm": { "$value": "0 2px 4px rgba(0,0,0,0.12)", "$description": "Dropdown, tooltip" },
    "md": { "$value": "0 4px 16px rgba(0,0,0,0.12)", "$description": "Panel, popover" },
    "lg": { "$value": "0 8px 32px rgba(0,0,0,0.16)", "$description": "Modal, context menu" }
  }
}
