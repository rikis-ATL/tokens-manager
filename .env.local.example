# MongoDB connection string (fallback — can also be configured via Settings > Database UI)
# Format: mongodb://[username:password@]host[:port]/database
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/atui-tokens-manager

# MongoDB Collection Name (optional)
# Default: 'tokencollections'
# Override to use a different collection (e.g., 'tokenCollections' for demo data)
# MONGODB_COLLECTION_NAME=tokencollections

# Demo Mode Configuration (optional - for public demo site)
# When true, auto-signs in visitors as demo@example.com (Demo role)
DEMO_MODE=false

# App shell theming (optional) — MongoDB id of the token collection that drives shadcn CSS variables for the UI chrome
# APP_THEME_COLLECTION_ID=

# Self-hosted deployment bypass (Phase 23 D-14)
# When true, all billing limit checks (collection count, token count, export rate, rate limiter)
# short-circuit before any DB read. Set to true for internal/self-hosted installs.
# Defaults to false/unset = limits active.
SELF_HOSTED=false
